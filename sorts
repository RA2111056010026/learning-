def bubblesort(c):
    i=0
    y=True
    b=len(c)
    while y:
        y=False
        for x in range(b-i-1):
            if c[x]<=c[x+1]:
                pass
            else:
                y=True
                c[x],c[x+1]=c[x+1],c[x]
        i +=1
